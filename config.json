{
  "name": "HA MCP Bridge",
  "version": "0.1.18",
  "slug": "ha-mcp-bridge",
  "description": "GitHub Copilot chat panel for Home Assistant, backed by an MCP server bridge.",
  "url": "https://github.com/Amantux/ha-mcp-bridge",
  "arch": [
    "amd64",
    "armv7",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "options": {
    "host": "0.0.0.0",
    "port": 8099
  },
  "ports": {
    "8099/tcp": 8099
  },
  "map": [
    "data:rw"
  ],
  "discovery": [
    "ha_mcp_bridge"
  ],
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:github",
  "panel_title": "Copilot",
  "schema": {
    "host": "str?",
    "port": "int?"
  }
}
