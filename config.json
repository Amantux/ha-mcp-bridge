{
  "name": "HA MCP Bridge",
  "version": "0.1.3",
  "slug": "ha-mcp-bridge",
  "description": "Supervisor add-on that bridges Home Assistant to an MCP (Model Context Protocol) server.",
  "url": "https://github.com/Amantux/ha-mcp-bridge",
  "arch": [
    "amd64",
    "armv7",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "options": {
    "host": "0.0.0.0",
    "port": 8099
  },
  "ports": {
    "8099/tcp": 8099
  },
  "map": [
    "data:rw"
  ],
  "discovery": [
    "ha_mcp_bridge"
  ],
  "schema": {
    "host": "str?",
    "port": "int?"
  }
}
